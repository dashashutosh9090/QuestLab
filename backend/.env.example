PORT=5000

# MongoDB connection string (Atlas or local)
MONGODB_URI=mongodb://localhost:27017/gamified-learning

# Long random string used to sign JWTs (use `openssl rand -hex 64`)
JWT_SECRET=replace_with_a_long_random_secret

# Google Gemini API key for AI quest generation
GEMINI_API_KEY=your_gemini_api_key_here

# Google OAuth client id used for "Sign in with Google"
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# Required to register as admin via /api/auth/register
ADMIN_SIGNUP_KEY=replace_with_a_secret_admin_key

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
